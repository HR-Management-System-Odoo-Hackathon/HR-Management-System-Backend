# Mongo
MONGO_URI=mongodb://localhost:27017/employee_management

# JWT
JWT_SECRET_KEY=change-this-to-a-long-random-string
JWT_EXP_HOURS=8

# Email verification token
EMAIL_TOKEN_SECRET=change-this-too
EMAIL_TOKEN_EXP_MINUTES=30

# Flask-Mail (use a real SMTP provider in production; Gmail example below)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# Frontend URL, used to build the verification link
FRONTEND_URL=http://localhost:3000

FLASK_ENV=development
